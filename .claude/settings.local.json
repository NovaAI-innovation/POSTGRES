{
  "permissions": {
    "allow": [
      "Bash(bash agent-state.sh pull)",
      "Skill(update-config)",
      "Bash(python -c ' *)",
      "Bash(echo \"exit: $?\")",
      "Bash(python *)",
      "Bash(winget install *)",
      "Bash(where.exe jq *)",
      "Bash(powershell -Command \"\\(Get-Command jq -ErrorAction SilentlyContinue\\).Source\")",
      "PowerShell(Get-Command *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/agent-state-hook.ps1 SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/agent-state-hook.ps1 UserPromptSubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/agent-state-hook.ps1 PreToolUse write-tools"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/agent-state-hook.ps1 PostToolUse write-tools"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/agent-state-hook.ps1 Notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/agent-state-hook.ps1 Stop"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/agent-state-hook.ps1 SubagentStop"
          }
        ]
      }
    ]
  }
}
