# App runtime
APP_ENV=production
LOG_LEVEL=INFO
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOOL_TIMEOUT_SECONDS=30

# Auth
AUTH_SECRET_CURRENT=replace-with-strong-secret
AUTH_SECRET_PREVIOUS=

# Comma-separated dev keys; keep empty in production unless needed.
INTERNAL_API_KEYS=

# Optional Supabase backing store.
# If left blank, repository defaults to in-memory.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gateway upstream auth material (used by agent profiles).
CLAUDE_GATEWAY_TOKEN=
CLAUDE_GATEWAY_API_KEY=
AGENT0_GATEWAY_TOKEN=
AGENT0_GATEWAY_API_KEY=
CODEX_GATEWAY_TOKEN=
CODEX_GATEWAY_API_KEY=
